<%- include('../partials/head') %>


    <%- include('../partials/navbar') %>

        <%- include('../partials/sidebar') %>

            <div class="page-wrapper">

                <div class="page-breadcrumb">
                    <div class="row">
                        <div class="col-5 align-self-center">
                            <h4 class="page-title">Dashboard</h4>
                            <div class="d-flex align-items-center">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item"><a href="#">Home</a></li>
                                        <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
                                    </ol>
                                </nav>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="container-fluid">

                    <% if (typeof success !=='undefined' && success) { %>
                        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2"
                            role="alert">
                            <i data-feather="check-circle" class="feather-sm flex-shrink-0"></i>
                            <%= success %>
                                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>

                            <% if (typeof error !=='undefined' && error) { %>
                                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2"
                                    role="alert">
                                    <i data-feather="alert-circle" class="feather-sm flex-shrink-0"></i>
                                    <%= error %>
                                        <button type="button" class="btn-close ms-auto"
                                            data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <!-- Top Cards -->
                                    <div class="row mb-4">

                                        <div class="col-xl-3 col-md-3 mb-3">
                                            <div class="card border-0 rounded-4 shadow-sm bg-primary text-white h-100">
                                                <div
                                                    class="card-body d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <p class="mb-2 text-uppercase small fw-semibold">Total Users</p>
                                                        <h1 class="fw-bold mb-0">
                                                            <%= stats.totalUsers %>
                                                        </h1>
                                                    </div>
                                                    <div class="icon-box">
                                                        <i class="ri-user-3-line fs-1 opacity-50"></i>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-xl-3 col-md-3 mb-3">
                                            <div class="card border-0 rounded-4 shadow-sm bg-success text-white h-100">
                                                <div
                                                    class="card-body d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <p class="mb-2 text-uppercase small fw-semibold">Total Orders
                                                        </p>
                                                        <h1 class="fw-bold mb-0">
                                                            <%= stats.totalOrders %>
                                                        </h1>
                                                    </div>
                                                    <div class="icon-box">
                                                        <i class="ri-shopping-cart-line fs-1 opacity-50"></i>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-xl-3 col-md-3 mb-3">
                                            <div class="card border-0 rounded-4 shadow-sm bg-warning text-white h-100">
                                                <div
                                                    class="card-body d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <p class="mb-2 text-uppercase small fw-semibold">Revenue</p>
                                                        <h1 class="fw-bold mb-0">₹<%=
                                                                Number(stats.totalRevenue).toFixed(2) %>
                                                        </h1>
                                                    </div>
                                                    <div class="icon-box">
                                                        <i class="ri-money-rupee-circle-line fs-1 opacity-50"></i>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-xl-3 col-md-3 mb-3">
                                            <div class="card border-0 rounded-4 shadow-sm bg-danger text-white h-100">
                                                <div
                                                    class="card-body d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <p class="mb-2 text-uppercase small fw-semibold">Active Users
                                                        </p>
                                                        <h1 class="fw-bold mb-0">
                                                            <%= stats.activeUsers %>
                                                        </h1>
                                                    </div>
                                                    <div class="icon-box">
                                                        <i class="ri-user-follow-line fs-1 opacity-50"></i>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                    </div>


                                    <!-- Dashboard Grid -->
                                    <div class="row">

                                        <!-- Low Stock Alerts -->
                                        <div class="col-xl-6 col-lg-6 mb-4">
                                            <div class="card border-0 rounded-4 shadow-sm h-100">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                                        <h4 class="card-title mb-0 fw-bold">Low Stock Alerts</h4>
                                                        <span class="badge bg-danger fs-1">Stock ≤ 5</span>
                                                    </div>

                                                    <% if (lowStockProducts.length> 0) { %>

                                                        <% lowStockProducts.forEach(product=> { %>
                                                            <div
                                                                class="d-flex align-items-center gap-3 py-3 border-bottom">

                                                                <div class="flex-shrink-0">
                                                                    <img src="<%= product.thumbnail || '/admin/public/images/placeholder.png' %>"
                                                                        alt="<%= product.product_title %>" width="50"
                                                                        height="50" class="rounded"
                                                                        style="object-fit:cover;">
                                                                </div>

                                                                <div class="flex-grow-1 overflow-hidden">
                                                                    <div class="fw-semibold text-dark text-truncate">
                                                                        <%= product.product_title %>
                                                                    </div>

                                                                    <small class="text-muted">
                                                                        Product ID: #<%= product.ID %>
                                                                    </small>
                                                                </div>

                                                                <div>
                                                                    <span class="badge bg-danger fs-3">
                                                                        <%= product.stock %> Left
                                                                    </span>
                                                                </div>

                                                            </div>
                                                            <% }) %>

                                                                <% } else { %>

                                                                    <div class="text-center py-5 text-muted">
                                                                        <i class="ri-checkbox-circle-line fs-1"></i>
                                                                        <p class="mt-2 mb-0">No low stock products</p>
                                                                    </div>

                                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Best Sellers -->
                                        <div class="col-xl-6 col-lg-6 mb-4">
                                            <div class="card border-0 rounded-4 shadow-sm h-100">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                                        <h4 class="card-title mb-0 fw-bold">Best Sellers</h4>
                                                        <span class="badge bg-success">Top 5</span>
                                                    </div>

                                                    <% bestSellers.forEach(item=> { %>
                                                        <div class="d-flex align-items-center gap-3 py-3 border-bottom">
                                                            <div class="flex-shrink-0 position-relative">
                                                                <img src="<%= item.thumbnail || '/admin/public/images/placeholder.png' %>"
                                                                    alt="<%= item.product_title %>" class="rounded"
                                                                    width="50" height="50" style="object-fit:cover;">
                                                                <span
                                                                    class="badge bg-success position-absolute bottom-0 end-0 translate-middle-y">
                                                                    <%= item.totalSold %>
                                                                </span>
                                                            </div>
                                                            <div class="flex-grow-1 overflow-hidden">
                                                                <div class="fw-semibold text-dark text-truncate">
                                                                    <%= item.product_title %>
                                                                </div>
                                                                <small class="text-muted d-block">Sold: <%=
                                                                        item.totalSold %></small>
                                                            </div>
                                                        </div>
                                                        <% }) %>
                                                </div>
                                            </div>
                                        </div>


                                        <!-- Latest Orders -->
                                        <div class="col-xl-4 col-lg-4 mb-4">
                                            <div class="card border-0 rounded-4 shadow-sm h-100">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                                        <h4 class="card-title mb-0 fw-bold">Latest Orders</h4>
                                                        <span class="badge bg-info">Recent</span>
                                                    </div>

                                                    <% latestOrders.forEach(order=> { %>
                                                        <div class="py-3 border-bottom">
                                                            <div
                                                                class="d-flex justify-content-between align-items-center">
                                                                <strong class="text-primary">#<%= order.order_id %>
                                                                        </strong>
                                                                <span class="badge text-capitalize
                                                    <%= order.order_status === 'wc-completed' ? 'bg-success' :
                                                        order.order_status === 'wc-processing' ? 'bg-primary' :
                                                        order.order_status === 'wc-pending' ? 'bg-warning text-dark' :
                                                        order.order_status === 'wc-on-hold' ? 'bg-info text-dark' :
                                                        'bg-secondary' %>">
                                                                    <%= order.order_status.replace('wc-', '' ) %>
                                                                </span>
                                                            </div>
                                                            <small class="text-muted d-block mt-1">
                                                                <%= new
                                                                    Date(order.order_date).toLocaleDateString('en-IN')
                                                                    %>
                                                            </small>
                                                        </div>
                                                        <% }) %>
                                                </div>
                                            </div>
                                        </div>


                                        <!-- Recent Users -->
                                        <div class="col-xl-4 col-lg-4 mb-4">
                                            <div class="card border-0 rounded-4 shadow-sm h-100">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                                        <h4 class="card-title mb-0 fw-bold">Recent Users</h4>
                                                        <span class="badge bg-primary">New</span>
                                                    </div>

                                                    <% recentUsers.forEach(user=> { %>
                                                        <div class="d-flex align-items-center gap-3 py-3 border-bottom">
                                                            <div class="avatar-sm rounded-circle bg-gradient text-white d-flex align-items-center justify-content-center flex-shrink-0"
                                                                style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-width:40px;">
                                                                <span class="fw-bold fs-6">
                                                                    <%= (user.display_name || user.user_email || '?'
                                                                        ).charAt(0).toUpperCase() %>
                                                                </span>
                                                            </div>
                                                            <div class="flex-grow-1 overflow-hidden">
                                                                <div class="fw-semibold text-dark text-truncate">
                                                                    <%= user.display_name %>
                                                                </div>
                                                                <small class="text-muted text-truncate d-block">
                                                                    <%= user.user_email %>
                                                                </small>
                                                            </div>
                                                        </div>
                                                        <% }) %>
                                                </div>
                                            </div>
                                        </div>


                                        <!-- Category Products -->
                                        <div class="col-xl-4 col-lg-4 mb-4">
                                            <div class="card border-0 rounded-4 shadow-sm h-100">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                                        <h4 class="card-title mb-0 fw-bold">Category Products</h4>
                                                        <span class="badge bg-warning text-dark">Featured</span>
                                                    </div>

                                                    <% categoryProducts.forEach(item=> { %>
                                                        <div class="py-3 border-bottom">
                                                            <div class="d-flex align-items-start gap-2">
                                                                <div class="flex-shrink-0">
                                                                    <span
                                                                        class="badge bg-primary bg-opacity-25 text-primary px-2 py-1 rounded-pill small fw-semibold">
                                                                        <%= item.category_name %>
                                                                    </span>
                                                                </div>
                                                            </div>
                                                            <small class="text-muted d-block mt-2 text-truncate">
                                                                📦 <%= item.product_title %>
                                                            </small>
                                                        </div>
                                                        <% }) %>
                                                </div>
                                            </div>
                                        </div>

                                    </div>

                </div>



            </div>

            </div>


            <div class="chat-windows"></div>

            <%- include('../partials/scripts') %>
                <%- include('../partials/footer') %>